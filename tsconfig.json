{
	"compilerOptions": {
		"target": "esnext",
		"module": "Preserve",
		"moduleDetection": "force",
		"lib": ["esnext"],
		"esModuleInterop": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"declaration": true,
		"outDir": "./dist",
		"strict": true,
		"newLine": "lf",
		"types": ["node"],
		"rootDir": "./lib"
	},
	"include": ["lib/**/*.ts", "lib/**/*.d.ts"],
	"exclude": ["node_modules"]
}
